# docker/.env — RMF demo configuration for `docker compose`.
#
# Copy this file to `docker/.env` (gitignored) and edit. Docker Compose
# auto-loads `.env` from this directory, so values below override the
# `${VAR:-default}` fallbacks in docker-compose.yaml. No need to export them.
#
#   cp docker/.env.example docker/.env
#   cd docker && docker compose up
#
# One-off override without editing the file:
#   DEMO_WORLD=hotel docker compose up

# Which demo world to launch ({DEMO_WORLD}_pybullet.launch.py):
#   office | airport_terminal | hotel | clinic | battle_royale
DEMO_WORLD=office

# PyBullet GUI window. false = headless (no X / WSL display needed).
GUI=true

# RViz. false = headless / saves CPU & GPU.
RVIZ=true

# ROS 2 domain isolation (keep all containers on the same id).
ROS_DOMAIN_ID=42
