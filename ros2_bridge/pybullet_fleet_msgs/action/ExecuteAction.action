# Goal
string robot_name
string action_type          # "move" | "pick" | "drop" | "wait" | "joint"
string action_params_json   # JSON-encoded parameters
---
# Result
bool success
string message
---
# Feedback
uint8 STATUS_NOT_STARTED=0
uint8 STATUS_IN_PROGRESS=1
uint8 STATUS_COMPLETED=2
uint8 STATUS_FAILED=3
uint8 STATUS_CANCELLED=4
uint8 status
float32 progress            # 0.0 ~ 1.0
